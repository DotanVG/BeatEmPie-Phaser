{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm test)",
      "Bash(git fetch:*)",
      "Bash(git status)",
      "Bash(git checkout:*)",
      "Bash(git merge --ff-only:*)"
    ],
    "deny": []
  }
}
